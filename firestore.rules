rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    // Admin is the user who requested the app
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'araizhasan00@gmail.com';
    }

    function isValidLearner(data) {
      return data.keys().hasAll(['id', 'fullName', 'password', 'isApproved', 'booksCompleted', 'presentationsGiven', 'tasksCompleted', 'joinedAt']) &&
             data.keys().size() == 8 &&
             data.id is string && data.id.size() <= 50 &&
             data.fullName is string && data.fullName.size() <= 100 &&
             data.password is string && data.password.size() <= 100 &&
             data.isApproved is bool &&
             data.booksCompleted is list && data.booksCompleted.size() <= 1000 &&
             data.presentationsGiven is list && data.presentationsGiven.size() <= 1000 &&
             data.tasksCompleted is number &&
             data.joinedAt is string;
    }

    match /learners/{learnerId} {
      // Public read allowed for leaderboard and sign-in check
      // However, we only allow reading if they are approved OR if the user is an admin
      allow read: if true; 

      // Allow registration with isApproved as false
      allow create: if (
        (isValidLearner(request.resource.data) && request.resource.data.isApproved == false) ||
        isAdmin()
      );

      // Only Admin can update or delete
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /edit_requests/{requestId} {
      allow read: if true; // Everyone can see pending status if we need, but admin is main reader
      allow create: if true; // Learners can request edits
      allow update, delete: if isAdmin();
    }
  }
}
